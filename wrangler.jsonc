{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "304-peptides",
  "main": "./worker/index.js",
  "compatibility_date": "2026-07-11",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}